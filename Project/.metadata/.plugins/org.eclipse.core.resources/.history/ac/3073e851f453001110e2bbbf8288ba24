uint32_t total_period = 0;   // 總週期（微秒）
uint32_t duty_cycle = 0;    // 占空比（百分比 %）
float frequency = 0.0;       // 頻率（Hz）


void HAL_TIM_IC_CaptureCallback(TIM_HandleTypeDef *htim)
{
    if (htim->Instance == TIM1)
    {
        // 如果是通道 1 觸發（上升沿：拿到總週期）
        if (htim->Channel == HAL_TIM_ACTIVE_CHANNEL_1)
        {
            // 讀取 CCR1 的數值，因為 PSC 設為 167，這個數值直接等於「幾微秒」
            total_period = HAL_TIM_ReadCapturedValue(htim, TIM_CHANNEL_1);

            if (total_period > 0)
            {
                // 計算頻率： 1秒(1000000微秒) / 總週期微秒
                frequency = 1000000.0 / total_period;
            }
        }
        // 如果是通道 2 觸發（下降沿：拿到高電平時間）
        else if (htim->Channel == HAL_TIM_ACTIVE_CHANNEL_2)
        {
            // 讀取 CCR2 的數值（高電平時間）
            uint32_t high_time = HAL_TIM_ReadCapturedValue(htim, TIM_CHANNEL_2);

            if (total_period > 0)
            {
                // 計算占空比 = (高電平時間 / 總週期) * 100
                duty_cycle = (high_time * 100) / total_period;
            }
        }
    }
}

